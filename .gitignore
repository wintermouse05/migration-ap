# Build output
target/
build/
out/

# Keep nested generated directories inside source trees if they are intentionally versioned.
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# Maven wrapper
!.mvn/wrapper/maven-wrapper.jar

# Java and runtime artifacts
*.class
*.log
logs/

