# Oracle source
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=ORCL
ORACLE_USER=scott
ORACLE_USER_PASSWORD=tiger

# Use UTC to avoid PostgreSQL timezone alias issues (e.g. Asia/Saigon).
APP_TIMEZONE=UTC

# Metadata extraction demo options
ENABLE_METADATA_TEST=true
METADATA_OUTPUT_FORMAT=json
SOURCE_SCHEMA=SCOTT
TARGET_SCHEMA=public
METADATA_MAX_TABLES=5

# Migration flow
MIGRATION_DIRECTION=ORACLE_TO_POSTGRES
MIGRATION_BATCH_SIZE=1000
MIGRATION_MAX_TABLES=0
MIGRATION_INCLUDE_TABLES=
MIGRATION_EXCLUDE_TABLES=
MIGRATION_SKIP_EXISTING_TABLES=true
MIGRATION_SKIP_EXISTING_FKS=true
MIGRATION_RECREATE_EXISTING_TABLES=false

# Retry/Resume
MIGRATION_ENABLE_RETRY=true
MIGRATION_MAX_ATTEMPTS=3
MIGRATION_RETRY_DELAY_MS=2000
MIGRATION_RETRY_BACKOFF_MULTIPLIER=2.0
MIGRATION_ENABLE_RESUME=true
MIGRATION_RESUME_STATE_FILE=.migration-resume.properties
MIGRATION_RESET_RESUME_STATE=false

# PostgreSQL target
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=migration_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123
